    <!-- LED_MUX — LED vif color on border -->
    <mxCell id="24" value="&lt;b&gt;LED_MUX&lt;/b&gt;&#xa;&#xa;Binary → BCD conversion  (overflow: error_q % 1,000,000)&#xa;6-digit time-multiplexing  (≥ 1002 cycles per value)&#xa;Propagation delay: 60–80 clock cycles after new error_q&#xa;&#xa;sel_out[5:0]  one-hot, active-low — one bit per digit&#xa;seg_out[6:0]  active-low segment drive  (0 = segment ON)&#xa;seg_out[7]    always 1 when segments are active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde9d9;strokeColor=#cc6600;fontSize=11;verticalAlign=top;align=left;spacingLeft=10;strokeWidth=2;" vertex="1" parent="1">
