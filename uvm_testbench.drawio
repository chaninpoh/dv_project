    <!-- APB SLAVE — APB vif color on border to echo the interface above -->
    <mxCell id="23" value="&lt;b&gt;APB SLAVE&lt;/b&gt;&#xa;&#xa;0x4000  LED_enable [RW]   default = 1&#xa;               (0 = disable error propagation)&#xa;&#xa;0x4004  Done        [RO]   default = 0&#xa;               (1 = seg_out is valid and stable)&#xa;&#xa;0x4008  Scratch Pad [RW]   default = 0&#xa;               (read-back must equal last write)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ddeeff;strokeColor=#3380cc;fontSize=11;verticalAlign=top;align=left;spacingLeft=10;strokeWidth=2;" vertex="1" parent="1">
